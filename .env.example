# Docker Hub (CI build & push)
DOCKERHUB_USERNAME=
DOCKERHUB_TOKEN=

# EC2 (CD deploy por SSH)
# EC2_HOST: IP elastica de la EC2
# USER_SERVER: ej ec2-user
# EC2_SSH_KEY: contenido del .pem (en GitHub: secret multilinea)
EC2_HOST=
USER_SERVER=
EC2_SSH_KEY=

# AWS S3 / region
# AWS_S3_BUCKET: nombre del bucket creado en el Lab
AWS_REGION=us-east-1
AWS_S3_BUCKET=

# AWS credenciales (SOLO si NO se usa el rol de instancia LabRole)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# Runtime de la app (microservicio productor: API REST + publica en las colas)
APP_IMAGE=dalvaes/gestion-despacho:latest
APP_EFS_DIR=/app/efs

# Runtime del microservicio consumidor (drena cola 1 y guarda en la tabla nueva)
CONSUMIDOR_IMAGE=dalvaes/gestion-despacho-consumidor:latest

# RabbitMQ (broker interno de Docker; ambos valores son obligatorios)
# Generar un secreto, por ejemplo: openssl rand -base64 32
RABBITMQ_USER=
RABBITMQ_PASS=
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672

# Base de datos: H2 en memoria por defecto (mismo motor que las sumativas anteriores).
# SPRING_DATASOURCE_URL / DRIVER / USERNAME / PASSWORD quedan disponibles como
# override por si en el futuro se necesita apuntar a otro motor.

HOST_EFS_DIR=/mnt/efs
SPRING_PROFILES_ACTIVE=

# Base de datos: H2 por defecto. Para Oracle, completar con valores del ambiente.
SPRING_DATASOURCE_URL=jdbc:h2:mem:guias;DB_CLOSE_DELAY=-1
SPRING_DATASOURCE_DRIVER=org.h2.Driver
SPRING_DATASOURCE_USERNAME=sa
SPRING_DATASOURCE_PASSWORD=
# SPRING_DATASOURCE_URL=jdbc:oracle:thin:@//<host>:1521/<service>
# SPRING_DATASOURCE_DRIVER=oracle.jdbc.OracleDriver
# SPRING_DATASOURCE_USERNAME=<usuario>
# SPRING_DATASOURCE_PASSWORD=<password>

# Microsoft Entra ID (OAuth2 Resource Server). Proporcionar estos valores por entorno.
# ISSUER_URI: https://login.microsoftonline.com/<tenant-id>/v2.0
# JWK_SET_URI: endpoint JWKS publicado por el tenant.
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_ISSUER_URI=
AZURE_JWK_SET_URI=
AZURE_ROLES_CLAIM=roles

# Solo para Postman / pruebas OAuth2. No se usan dentro del backend.
AZURE_AUTH_URL=
AZURE_TOKEN_URL=
AZURE_API_SCOPE=
AZURE_POSTMAN_CLIENT_ID=
AZURE_POSTMAN_CLIENT_SECRET=
