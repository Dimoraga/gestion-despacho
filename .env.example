# Docker Hub (CI build & push)
DOCKERHUB_USERNAME=
DOCKERHUB_TOKEN=

# EC2 (CD deploy por SSH)
# EC2_HOST: IP elastica de la EC2
# USER_SERVER: ej ec2-user
# EC2_SSH_KEY: contenido del .pem (en GitHub: secret multilinea)
EC2_HOST=
USER_SERVER=
EC2_SSH_KEY=

# AWS S3 / region
# AWS_S3_BUCKET: nombre del bucket creado en el Lab
AWS_REGION=us-east-1
AWS_S3_BUCKET=

# AWS credenciales (SOLO si NO se usa el rol de instancia LabRole)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# Runtime de la app
APP_IMAGE=dalvaes/gestion-despacho:latest
APP_EFS_DIR=/app/efs
HOST_EFS_DIR=/mnt/efs
SPRING_PROFILES_ACTIVE=

# RabbitMQ local / compose
SPRING_RABBITMQ_HOST=rabbitmq
SPRING_RABBITMQ_PORT=5672
SPRING_RABBITMQ_USERNAME=guest
SPRING_RABBITMQ_PASSWORD=guest
APP_RABBITMQ_QUEUE=guia-despacho.queue
APP_RABBITMQ_EXCHANGE=guia-despacho.exchange
APP_RABBITMQ_ROUTING_KEY=guia-despacho.creada

# Base de datos: H2 por defecto. Para Oracle, completar con valores del ambiente.
SPRING_DATASOURCE_URL=jdbc:h2:mem:guias;DB_CLOSE_DELAY=-1
SPRING_DATASOURCE_DRIVER=org.h2.Driver
SPRING_DATASOURCE_USERNAME=sa
SPRING_DATASOURCE_PASSWORD=
# SPRING_DATASOURCE_URL=jdbc:oracle:thin:@//<host>:1521/<service>
# SPRING_DATASOURCE_DRIVER=oracle.jdbc.OracleDriver
# SPRING_DATASOURCE_USERNAME=<usuario>
# SPRING_DATASOURCE_PASSWORD=<password>

# Azure AD B2C / IDaaS
# Ejemplo TENANT: miduocb2c.onmicrosoft.com
# Ejemplo USER_FLOW: B2C_1_signupsignin
# JWK_SET_URI típico:
# https://<tenant>.b2clogin.com/<tenant>.onmicrosoft.com/<policy>/discovery/v2.0/keys
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_B2C_USER_FLOW=B2C_1_signupsignin
AZURE_ISSUER_URI=
AZURE_JWK_SET_URI=

# Solo para Postman / pruebas OAuth2. No se usan dentro del backend.
AZURE_AUTH_URL=
AZURE_TOKEN_URL=
AZURE_API_SCOPE=
AZURE_POSTMAN_CLIENT_ID=
AZURE_POSTMAN_CLIENT_SECRET=
