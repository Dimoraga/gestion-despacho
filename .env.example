# Docker Hub (CI build & push)
DOCKERHUB_USERNAME=
DOCKERHUB_TOKEN=

# EC2 (CD deploy por SSH)
# EC2_HOST: IP elastica de la EC2
# USER_SERVER: ej ec2-user
# EC2_SSH_KEY: contenido del .pem (en GitHub: secret multilinea)
EC2_HOST=
USER_SERVER=
EC2_SSH_KEY=

# AWS S3 / region
# AWS_S3_BUCKET: nombre del bucket creado en el Lab
AWS_REGION=us-east-1
AWS_S3_BUCKET=

# AWS credenciales (SOLO si NO se usa el rol de instancia LabRole)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# Runtime de la app
APP_IMAGE=dalvaes/gestion-despacho:latest
APP_EFS_DIR=/app/efs
