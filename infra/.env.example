# Docker Hub (CI build & push)
DOCKERHUB_USERNAME=
DOCKERHUB_TOKEN=

# EC2 (CD deploy por SSH)
# EC2_HOST: IP elastica de la EC2
# USER_SERVER: ej ec2-user
# EC2_SSH_KEY: contenido del .pem (en GitHub: secret multilinea)
EC2_HOST=
USER_SERVER=
EC2_SSH_KEY=

# AWS S3 / region
# AWS_S3_BUCKET: nombre del bucket creado en el Lab
AWS_REGION=us-east-1
AWS_S3_BUCKET=

# AWS credenciales (SOLO si NO se usa el rol de instancia LabRole)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# Runtime de la app (microservicio productor: API REST + publica en las colas).
# Obligatorio para el Compose cloud; usar una etiqueta inmutable del despliegue.
APP_IMAGE=
# URL interna del consumidor. En Compose dev usa el nombre del servicio Docker;
# sobrescribir sólo cuando el consumidor se ejecute fuera de esa red.
CONSUMIDOR_INTERNAL_URL=http://consumidor:8082

# Runtime del microservicio consumidor (listener automático: persiste, genera PDF en EFS y sube a S3)
CONSUMIDOR_IMAGE=

# RabbitMQ (broker interno de Docker; ambos valores son obligatorios)
# Reemplazar antes de desplegar; generar un secreto, por ejemplo: openssl rand -base64 32
RABBITMQ_USER=change-me
RABBITMQ_PASS=change-me
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672

# EFS compartido: subdirectorio de un montaje EFS real en EC2, usado por ambos servicios.
# El CD crea este subdirectorio con propietario/grupo del usuario no-root del consumidor.
HOST_EFS_DIR=/mnt/efs/gestion-despacho-consumidor
APP_EFS_DIR=/app/efs
SPRING_PROFILES_ACTIVE=

# Oracle Free del Compose cloud. El init SQL crea objetos en FREEPDB1.DESPACHO.
# Todos los valores son obligatorios; no usar H2 en este archivo.
ORACLE_SYSTEM_PASSWORD=
ORACLE_APP_USER=
ORACLE_APP_PASSWORD=
CONSUMIDOR_SPRING_DATASOURCE_URL=jdbc:oracle:thin:@//oracle:1521/FREEPDB1

# Microsoft Entra ID (OAuth2 Resource Server). Proporcionar estos valores por entorno.
# ISSUER_URI: https://login.microsoftonline.com/<tenant-id>/v2.0
# JWK_SET_URI: endpoint JWKS publicado por el tenant.
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_ISSUER_URI=
AZURE_JWK_SET_URI=
AZURE_ROLES_CLAIM=roles

# Solo para Postman / pruebas OAuth2. No se usan dentro del backend.
AZURE_AUTH_URL=
AZURE_TOKEN_URL=
AZURE_API_SCOPE=
AZURE_POSTMAN_CLIENT_ID=
AZURE_POSTMAN_CLIENT_SECRET=
